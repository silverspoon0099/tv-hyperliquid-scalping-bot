{
  "name": "hyperliquid-scalping-bot",
  "version": "0.1.0",
  "description": "High-performance low-latency Hyperliquid perpetual scalping bot with TradingView webhook integration",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc && npm run copy-config",
    "copy-config": "cp src/config/*.json dist/config/",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "docker:build": "docker build -t hyperliquid-bot .",
    "docker:testnet": "docker-compose -f docker-compose.yml up bot-testnet",
    "docker:mainnet": "docker-compose -f docker-compose.yml up bot-mainnet"
  },
  "keywords": [
    "hyperliquid",
    "scalping",
    "trading",
    "bot",
    "perpetual",
    "futures"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.1",
    "viem": "^2.0.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1"
  }
}
