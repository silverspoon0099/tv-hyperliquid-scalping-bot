# Environment selection
ENV=testnet

# ============================================================
# DUAL WALLET SETUP
# Long-wallet: only opens LONG positions
# Short-wallet: only opens SHORT positions
# ============================================================

# Long Wallet Private Keys (hex format: 0x + 64 hex chars)
LONG_WALLET_TESTNET_PRIVATE_KEY=0x...
LONG_WALLET_MAINNET_PRIVATE_KEY=0x...

# Short Wallet Private Keys (hex format: 0x + 64 hex chars)
SHORT_WALLET_TESTNET_PRIVATE_KEY=0x...
SHORT_WALLET_MAINNET_PRIVATE_KEY=0x...

# WEBHOOK_SECRET for TradingView Integration
# Generate a random secret key and use it in TradingView webhook configuration
# Example: openssl rand -hex 32
# Set this same value in TradingView alert webhook URL as query parameter
# Example webhook URL: http://your-server.com/webhook?secret=YOUR_WEBHOOK_SECRET
WEBHOOK_SECRET=generate-a-random-secret-key-here

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Trading Parameters
# MAX_POSITION_SIZE: Maximum order size in BASE CURRENCY (not USDT)
# Example: MAX_POSITION_SIZE=10 means max 10 BTC for BTCUSDC, max 100 ETH for ETHUSDC
MAX_POSITION_SIZE=10

# MIN_ORDER_SIZE: Minimum order size in BASE CURRENCY (not USDT)
# Example: MIN_ORDER_SIZE=0.01 means min 0.01 BTC for BTCUSDC, min 0.1 ETH for ETHUSDC
MIN_ORDER_SIZE=0.01

# MAX_LEVERAGE: Maximum leverage for orders (1 = no leverage, 5 = 5x)
MAX_LEVERAGE=5

# RATE_LIMIT_MS: Milliseconds between orders for SAME symbol+action (prevents duplicate trades)
# Default: 60000 (1 minute)
# Examples:
#   1000 = 1 second (very strict, only for high-frequency)
#   60000 = 1 minute
#   300000 = 5 minutes (recommended for TradingView alerts)
#   3600000 = 1 hour (very loose)
RATE_LIMIT_MS=60000

# MARKET_ORDER_SLIPPAGE_PERCENT: Price slippage for market orders (default 10%)
# Hyperliquid rejects if price is too far from oracle (varies, 10% is safe)
MARKET_ORDER_SLIPPAGE_PERCENT=10
